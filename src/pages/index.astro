<style>

.top{
  display:flex;
  justify-content:space-between;
  margin-bottom:5rem;
}

.hero-grid{
  display:grid;
  grid-template-columns:minmax(0,1.15fr) minmax(380px,.85fr);

  gap:18rem;

  align-items:start;

  margin-top:4rem;

  min-height:95vh;
}
.hero-title{
  font-size:clamp(8rem,14vw,18rem);

  font-weight:300;

  line-height:.82;

  letter-spacing:-0.09em;

  text-transform:lowercase;

  max-width:7ch;
}

.hero-image{
  position:relative;

  height:92vh;

  overflow:hidden;

  border:none;
}
.hero-image img{
  width:100%;

  height:100%;

  object-fit:cover;

  object-position:center top;

  filter:grayscale(100%) contrast(1.08);

  transition:transform .8s ease;
}

.hero-image:hover img{
  transform:scale(1.02);
}
.editorial{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:4rem;
  margin-top:4rem;
  max-width:1100px;
}

.editorial p{
  line-height:2;
}

.section-title{
  font-size:clamp(5rem,10vw,12rem);
  margin-bottom:3rem;
}

.entry{
  display:grid;
  grid-template-columns:100px 1fr;
  padding:2rem 0;
  border-top:1px solid var(--line);
}

.entry h3{
  font-size:2.5rem;
  text-transform:lowercase;
}

.works{
  display:flex;
  flex-direction:column;
  gap:1rem;
}

.works a{
  font-size:clamp(2rem,5vw,5rem);
  text-transform:lowercase;
}

.manifesto{
  font-size:clamp(5rem,10vw,12rem);
}

.contact{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:3rem;
}

@media(max-width:900px){

.hero-grid{
grid-template-columns:1fr;
}

.editorial{
grid-template-columns:1fr;
}

.contact{
grid-template-columns:1fr;
}

.top{
flex-direction:column;
gap:1rem;
}

}

</style>